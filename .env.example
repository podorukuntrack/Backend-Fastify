# ==========================================
# ENV TEMPLATE UNTUK BACKEND FASTIFY
# Copy file ini menjadi .env lalu sesuaikan
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=development # Ubah ke 'production' di VPS
FRONTEND_URL=http://localhost:5173,http://localhost:3000 # Ganti dengan domain frontend di VPS (misal https://podorukuntrack.com)

# Database PostgreSQL
DATABASE_URL=postgres://podorukuntrack_user:podorukuntrack_secret@localhost:5432/podorukuntrack

# Redis Configuration (Kosongkan REDIS_URL jika ingin fallback otomatis ke localhost:6379 di lokal)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=rahasia_jwt_super_aman_untuk_development_123
JWT_REFRESH_SECRET=aman_banget_kok

# Cloudflare R2 Storage (Untuk Upload Dokumen)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# WhatsApp API Configuration (Untuk Notifikasi & Reset Password)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
